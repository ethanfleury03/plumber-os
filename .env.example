# --- Clerk (required for portal + proxy) — set both keys; see https://clerk.com/docs/nextjs/getting-started/quickstart ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# In Clerk Dashboard → User & authentication → Social connections → Google (custom OAuth app) add scope:
#   https://www.googleapis.com/auth/gmail.send
# For Microsoft, add delegated scope: https://graph.microsoft.com/Mail.Send
# Users must sign in with Google or Microsoft (or link that account) so Clerk can mint provider tokens.

# --- Database ---
# When DATABASE_URL is set, the app uses Postgres (Neon) via drizzle-orm.
# When unset, it falls back to SQLite at ./data/plumberos.db (dev/test only).
# DATABASE_URL=postgres://user:pass@ep-xxxx.us-east-1.aws.neon.tech/plumberos?sslmode=require
# SQLITE_PATH=C:\path\to\custom.db

# --- Clerk webhook (portal_users sync) ---
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Optional: Supabase (only if you re-enable client/auth against Supabase)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional OpenClaw integration
OPENCLAW_API_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your_gateway_token

# --- App URL (required for Twilio webhook signature verification) ---
# APP_BASE_URL=https://your-public-host.example.com
# NEXT_PUBLIC_APP_BASE_URL=https://your-public-host.example.com

# --- AI Receptionist: mode (informational; mock works with no keys) ---
# RECEPTIONIST_PROVIDER=mock

# --- Retell (live voice + custom functions) ---
# RETELL_API_KEY=
# RETELL_AGENT_ID=
# RETELL_LLM_ID=
# RETELL_AGENT_NAME=PlumberOS Receptionist
# RETELL_VOICE_ID=
# RETELL_LLM_MODEL=gpt-4.1-mini
# RETELL_S2S_MODEL=
# RETELL_VERIFY_WEBHOOKS=true
# RETELL_TOOL_SHARED_SECRET=
# RECEPTIONIST_DEV_BYPASS_RETELL_SIGNATURE=false
# RECEPTIONIST_TOOL_DEBUG=true

# --- Twilio (inbound PSTN → webhook → Retell SIP) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# TWILIO_VERIFY_SIGNATURES=true
# RECEPTIONIST_DEV_BYPASS_TWILIO_SIGNATURE=false

# --- Receptionist scheduling hints ---
# RECEPTIONIST_DEFAULT_TIMEZONE=America/Toronto

# --- Estimates / quotes delivery ---
# Email (Resend): set both to send real email from Send / log delivery (channel email or auto with email on file).
# RESEND_API_KEY=
# ESTIMATE_FROM_EMAIL=Estimates <onboarding@resend.dev>
# SMS (Twilio): same vars as receptionist; from number is TWILIO_PHONE_NUMBER or TWILIO_FROM_NUMBER
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+15551234567
# Legacy fallback: ESTIMATE_DELIVERY_PROVIDER=mock|console (see delivery.ts)
# ESTIMATE_DELIVERY_PROVIDER=mock
# Public token routes: max requests per IP+token per window (default 40 per 60s)
# PUBLIC_ACTION_RATE_LIMIT_MAX=40
# PUBLIC_ACTION_RATE_LIMIT_WINDOW_SEC=60
# Backward-compatible aliases:
# PUBLIC_ESTIMATE_RATE_LIMIT_MAX=40
# PUBLIC_ESTIMATE_RATE_LIMIT_WINDOW_SEC=60

# Runtime DB setup route (disabled by default; dev-only POST)
# ALLOW_RUNTIME_SETUP=true
# PLUMBEROS_SETUP_TOKEN=change-me

# --- Stripe (Connect marketplace: platform + per-company connected accounts) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...              # main account webhook (account events)
# STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...      # Connect webhook (connected-account events)
# PLATFORM_FEE_BPS=290                         # 2.9% platform application fee; set "0" to disable
# APP_BASE_URL and NEXT_PUBLIC_APP_BASE_URL should be your public origin (used for Checkout return URLs).

# --- Cloudflare R2 (attachments + signatures) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=https://cdn.example.com

# --- Observability ---
# SENTRY_DSN=                         # server + client; tagged with company_id
# NEXT_PUBLIC_SENTRY_DSN=
# LOG_LEVEL=info
# AXIOM_TOKEN=                        # or LOGTAIL_SOURCE_TOKEN; shipped via vercel log drains

# --- Background jobs (Inngest) ---
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# --- Uptime / status ---
# BETTERSTACK_UPTIME_HEARTBEAT_URL=   # optional cron heartbeat pinged from /api/health

# Future LLM keys (not wired in receptionist core)
# OPENAI_API_KEY=

# --- Marketing image generator (offline tool only) ---
# Used by scripts/generate_landing_images.py to produce public/landing/*.jpg
# from gemini-2.5-flash-image ("Nano Banana"). Not read by the Next.js app.
# GEMINI_API_KEY=

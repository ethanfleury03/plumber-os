# --- Clerk (required for portal + proxy) — set both keys; see https://clerk.com/docs/nextjs/getting-started/quickstart ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# In Clerk Dashboard → User & authentication → Social connections → Google (custom OAuth app) add scope:
#   https://www.googleapis.com/auth/gmail.send
# For Microsoft, add delegated scope: https://graph.microsoft.com/Mail.Send
# Users must sign in with Google or Microsoft (or link that account) so Clerk can mint provider tokens.

# SQLite (default: ./data/plumberos.db — committed for local dev)
# SQLITE_PATH=C:\path\to\custom.db

# Optional: Supabase (only if you re-enable client/auth against Supabase)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional OpenClaw integration
OPENCLAW_API_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your_gateway_token

# --- App URL (required for Twilio webhook signature verification) ---
# APP_BASE_URL=https://your-public-host.example.com
# NEXT_PUBLIC_APP_BASE_URL=https://your-public-host.example.com

# --- AI Receptionist: mode (informational; mock works with no keys) ---
# RECEPTIONIST_PROVIDER=mock

# --- Retell (live voice + custom functions) ---
# RETELL_API_KEY=
# RETELL_AGENT_ID=
# RETELL_LLM_ID=
# RETELL_AGENT_NAME=PlumberOS Receptionist
# RETELL_VOICE_ID=
# RETELL_LLM_MODEL=gpt-4.1-mini
# RETELL_S2S_MODEL=
# RETELL_VERIFY_WEBHOOKS=true
# RETELL_TOOL_SHARED_SECRET=
# RECEPTIONIST_DEV_BYPASS_RETELL_SIGNATURE=false
# RECEPTIONIST_TOOL_DEBUG=true

# --- Twilio (inbound PSTN → webhook → Retell SIP) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# TWILIO_VERIFY_SIGNATURES=true
# RECEPTIONIST_DEV_BYPASS_TWILIO_SIGNATURE=false

# --- Receptionist scheduling hints ---
# RECEPTIONIST_DEFAULT_TIMEZONE=America/Toronto

# --- Estimates / quotes delivery ---
# Email (Resend): set both to send real email from Send / log delivery (channel email or auto with email on file).
# RESEND_API_KEY=
# ESTIMATE_FROM_EMAIL=Estimates <onboarding@resend.dev>
# SMS (Twilio): same vars as receptionist; from number is TWILIO_PHONE_NUMBER or TWILIO_FROM_NUMBER
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+15551234567
# Legacy fallback: ESTIMATE_DELIVERY_PROVIDER=mock|console (see delivery.ts)
# ESTIMATE_DELIVERY_PROVIDER=mock
# Public estimate pages: max requests per IP+token per window (default 40 per60s)
# PUBLIC_ESTIMATE_RATE_LIMIT_MAX=40
# PUBLIC_ESTIMATE_RATE_LIMIT_WINDOW_SEC=60

# Future LLM keys (not wired in receptionist core)
# OPENAI_API_KEY=
